# =============================================================================
# BizCollab ERP/CRM - Frontend Environment Configuration
# =============================================================================
# 
# IMPORTANT: 
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. These variables are prefixed with VITE_ to be accessible in the app
#
# =============================================================================

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------

# Backend API URL
VITE_BACKEND_SERVER=http://localhost:8888/

# Development mode (local | remote)
VITE_DEV_REMOTE=local


# -----------------------------------------------------------------------------
# FILE SERVER CONFIGURATION
# -----------------------------------------------------------------------------

# Base URL for uploaded files
VITE_FILE_BASE_URL=http://localhost:8888/public/

# Download base URL
VITE_DOWNLOAD_BASE_URL=http://localhost:8888/download/


# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# App name
VITE_APP_NAME=BizCollab

# App version
VITE_APP_VERSION=1.0.0

# Default language
VITE_DEFAULT_LANGUAGE=en_us

# Default currency
VITE_DEFAULT_CURRENCY=INR


# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

# Enable/disable features
# VITE_ENABLE_DARK_MODE=false
# VITE_ENABLE_NOTIFICATIONS=true
# VITE_ENABLE_ANALYTICS=false


# -----------------------------------------------------------------------------
# THIRD-PARTY SERVICES (Optional)
# -----------------------------------------------------------------------------

# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry (Error tracking)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Google Maps API (for address autocomplete)
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key


# -----------------------------------------------------------------------------
# PRODUCTION OVERRIDES
# -----------------------------------------------------------------------------
# Uncomment and set these for production deployment

# VITE_BACKEND_SERVER=https://api.yourdomain.com/
# VITE_FILE_BASE_URL=https://api.yourdomain.com/public/
# VITE_DOWNLOAD_BASE_URL=https://api.yourdomain.com/download/


# =============================================================================
# END OF CONFIGURATION
# =============================================================================
