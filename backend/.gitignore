# =============================================================================
# BizCollab Backend - Git Ignore File
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
*.env
!.env.example

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Uploads & Public Files
# -----------------------------------------------------------------------------
public/uploads/*
!public/uploads/.gitkeep
public/downloads/*
!public/downloads/.gitkeep
public/temp/*
!public/temp/.gitkeep

# -----------------------------------------------------------------------------
# Database Backups
# -----------------------------------------------------------------------------
backups/
*.dump
*.backup
*.sql

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------
dist/
build/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
.tmp/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/

# =============================================================================
# END OF BACKEND .gitignore
# =============================================================================