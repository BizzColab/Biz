# BizCollab ERP & CRM - Backend Environment Variables

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# The port where the backend server will run
PORT=8888
# Environment (development | production)
NODE_ENV=development

# ==========================================
# SECURITY CONFIGURATION (Arcjet)
# ==========================================
# Get your key from https://arcjet.com
ARCJET_KEY=aj_live_...

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Primary MongoDB connection string (Core Database)
# Multi-tenant databases will be created automatically using hashes
DATABASE=mongodb://localhost:27010/BizCollab_core

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# Secret key for signing JWT tokens (Use a long random string)
# Keep this secure in production!
JWT_SECRET=your_secret_key_here_at_least_32_characters_long

# ==========================================
# FILE UPLOAD & STORAGE
# ==========================================
# Base URL for public access to uploaded files
# In development, this is typically your local server URL
VITE_FILE_BASE_URL=http://localhost:8888/public/

# ==========================================
# EMAIL CONFIGURATION (Optional - for notifications/invoices)
# ==========================================
# Examples for popular services (choose one)

# Resend API Key
# RESEND_API_KEY=re_your_api_key

# SMTP Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# EMAIL_FROM=hello@bizcollab.com

# ==========================================
# GEMINI / AI CONFIGURATION (Optional - for AI features)
# ==========================================
# Get your key from Google AI Studio: https://aistudio.google.com/
# GEMINI_API_KEY=AIzaSyB...
# GEMINI_MODEL=gemma-3-12b-it

# ==========================================
# AWS S3 STORAGE (Optional - if using cloud storage instead of local)
# ==========================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
